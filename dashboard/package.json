{
  "name": "@andromeda/dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Andromeda local dashboard — Vite + React + TS + Tailwind + Zustand SPA, talks to the MCP control plane.",
  "scripts": {
    "dev": "vite",
