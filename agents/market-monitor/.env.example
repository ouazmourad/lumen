# Andromeda market-monitor configuration

# HTTP port to listen on
PORT=3100

# Where to register
ANDROMEDA_REGISTRY_URL=http://localhost:3030

# Public URL the registry should advertise to clients (defaults to http://localhost:$PORT)
# ANDROMEDA_PROVIDER_PUBLIC_URL=

# DB path (default: <repo>/agents/market-monitor/monitor.db)
# ANDROMEDA_MONITOR_DB_PATH=

# Provider keypair (auto-generated on first run, persisted to .env)
# ANDROMEDA_PROVIDER_PRIVKEY=

# Mock mode — uses fixture file in src/fixtures/advisories.json
# In real mode, polls https://api.github.com/advisories every 60s.
MOCK_MODE=true

# L402 macaroon secret (64+ chars). Required to sign alerts.
L402_SECRET=monitor-dev-secret-1234567890abcdef1234567890abcdef

# Watcher loop interval (ms). Defaults to 5000 in mock, 60000 in real.
# WATCHER_INTERVAL_MS=
