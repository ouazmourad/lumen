# ─── Where the LUMEN provider lives ─────────────────────────────
# default: http://localhost:3000  (run `npm run provider` in repo root)
LUMEN_PROVIDER_URL=http://localhost:3000

# ─── Wallet (NWC) ───────────────────────────────────────────────
# Same kind of string the buyer/.env uses. Reuse your lumen-buyer
# Alby app, OR create a third app 'lumen-mcp' so you can rotate it
# independently of the buyer CLI.
NWC_URL=

# ─── Mode ───────────────────────────────────────────────────────
# true  = mock; no sats moved; the LUMEN dev faucet hands the
#         server a preimage. Useful for first-time setup with
#         Claude Desktop without putting your wallet at risk.
# false = real Lightning; sats actually leave your wallet.
MOCK_MODE=true

# ─── Spending guardrails ────────────────────────────────────────
# Per-call cap: refuse any single invoice above this price.
MAX_PRICE_SATS=4000
# Per-session budget: refuse any spend that would breach this cap.
# Reset via the lumen_set_budget tool.
MAX_BUDGET_SATS=5000
