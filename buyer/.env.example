# ─── Where to buy from ──────────────────────────────────────────
PROVIDER_URL=http://localhost:3000

# ─── Wallet (NWC) ───────────────────────────────────────────────
# Paste the NWC string from Alby Hub for a SECOND app named "lumen-buyer".
# Looks like: nostr+walletconnect://<pubkey>?relay=wss://...&secret=...
NWC_URL=

# ─── Mock mode ──────────────────────────────────────────────────
# true  = no wallet needed; the buyer asks the provider's /api/dev/pay
#         endpoint for the preimage. Use this for first-pass testing.
# false = real Lightning. Pays the bolt-11 invoice via NWC_URL above.
MOCK_MODE=true

# ─── Spending policy ────────────────────────────────────────────
MAX_PRICE_SATS=4000
TIMEOUT_MS=15000
